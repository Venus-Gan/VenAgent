# VenAgent 本地环境变量模板
# 复制为仓库根目录 .env；真实 .env 已被 Git 忽略，不要提交真实凭据。

VENAGENT_LLM__API_URL=
VENAGENT_LLM__API_KEY=
VENAGENT_LLM__MODEL=
VENAGENT_EMBEDDING__API_URL=
VENAGENT_EMBEDDING__API_KEY=
VENAGENT_EMBEDDING__MODEL=

VENAGENT_POSTGRES__HOST=localhost
VENAGENT_POSTGRES__PORT=5432
VENAGENT_POSTGRES__USER=
VENAGENT_POSTGRES__PASSWORD=
VENAGENT_POSTGRES__DATABASE=

VENAGENT_SERVER__PORT=8090
VENAGENT_SANDBOX__ENABLED=false
